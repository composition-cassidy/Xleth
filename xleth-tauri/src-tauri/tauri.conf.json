{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XLETH",
  "version": "0.1.0",
  "identifier": "app.xleth.tauri",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "XLETH",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
