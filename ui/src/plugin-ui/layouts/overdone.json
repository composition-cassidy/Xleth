{
  "$xleth": "plugin-ui-layout",
  "schemaVersion": 1,
  "pluginId": "overdone",
  "name": "Default Overdone Layout",
  "panel": {
    "preferredSize": { "width": 540, "height": 408 }
  },
  "root": {
    "id": "root",
    "type": "panel",
    "children": [
      {
        "id": "viz-row",
        "type": "row",
        "style": { "paddingPx": [12, 12, 8, 12] },
        "children": [
          {
            "id": "overdone-viz",
            "type": "visualizer",
            "style": { "growsToFill": true },
            "props": {
              "source": "overdone.multiband",
              "preset": "overdoneMultiband",
              "heightPx": 214
            }
          }
        ]
      },
      {
        "id": "body",
        "type": "row",
        "style": { "paddingPx": [12, 10, 10, 10], "gapPx": 0, "align": "start", "justify": "center" },
        "children": [
          { "id": "s-depth",      "type": "compressorSlider", "style": { "widthPx": 58 }, "props": { "param": "depth",      "label": "DEPTH",    "format": "pct0" } },
          { "id": "s-time",       "type": "compressorSlider", "style": { "widthPx": 58 }, "props": { "param": "time",       "label": "TIME",     "format": "pct0" } },
          { "id": "divider-time-gain", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          { "id": "s-gain-low",   "type": "compressorSlider", "style": { "widthPx": 58 }, "props": { "param": "gain_low",   "label": "LOW",      "format": "dB1_signed" } },
          { "id": "s-gain-mid",   "type": "compressorSlider", "style": { "widthPx": 58 }, "props": { "param": "gain_mid",   "label": "MID",      "format": "dB1_signed" } },
          { "id": "s-gain-high",  "type": "compressorSlider", "style": { "widthPx": 58 }, "props": { "param": "gain_high",  "label": "HIGH",     "format": "dB1_signed" } },
          { "id": "divider-gain-xover", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          { "id": "s-xover-low",  "type": "compressorSlider", "style": { "widthPx": 64 }, "props": { "param": "xover_low",  "label": "LO XOVER", "format": "hz_smart" } },
          { "id": "s-xover-high", "type": "compressorSlider", "style": { "widthPx": 64 }, "props": { "param": "xover_high", "label": "HI XOVER", "format": "hz_smart" } }
        ]
      }
    ]
  }
}
