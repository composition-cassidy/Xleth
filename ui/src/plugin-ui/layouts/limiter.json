{
  "$xleth": "plugin-ui-layout",
  "schemaVersion": 1,
  "pluginId": "limiter",
  "name": "Block Limiter Layout",
  "panel": {
    "preferredSize": { "width": 540, "height": 408 }
  },
  "root": {
    "id": "root",
    "type": "panel",
    "children": [
      {
        "id": "viz-row",
        "type": "row",
        "style": { "paddingPx": [12, 12, 8, 12] },
        "children": [
          {
            "id": "limiter-viz",
            "type": "visualizer",
            "style": { "growsToFill": true },
            "props": {
              "source": "limiter.realtime",
              "preset": "limiterRealtime",
              "heightPx": 214
            }
          }
        ]
      },
      {
        "id": "body",
        "type": "row",
        "style": { "paddingPx": [12, 10, 8, 10], "gapPx": 0, "align": "start", "justify": "center" },
        "children": [
          { "id": "s-gain",    "type": "compressorSlider", "style": { "widthPx": 78 }, "props": { "param": "gain",    "label": "GAIN",    "format": "dB1" } },
          { "id": "s-ceiling", "type": "compressorSlider", "style": { "widthPx": 78 }, "props": { "param": "ceiling", "label": "CEILING", "format": "dB1" } },
          { "id": "divider-ceiling-release", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          { "id": "s-release", "type": "compressorSlider", "style": { "widthPx": 78 }, "props": { "param": "release", "label": "RELEASE", "format": "ms0" } },
          { "id": "divider-release-meter", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          {
            "id": "gr-meter",
            "type": "meter",
            "style": { "widthPx": 48, "heightPx": 122 },
            "props": {
              "source": { "kind": "effectMeter", "slot": "GAIN_REDUCTION" },
              "label": "GR",
              "unit": "dB",
              "range": { "min": 0, "max": 40, "scale": "linear" },
              "orientation": "vertical",
              "format": "dB1"
            }
          }
        ]
      },
      {
        "id": "style-row",
        "type": "row",
        "style": { "paddingPx": [6, 12, 10, 12], "gapPx": 6, "align": "center", "justify": "center" },
        "props": { "variant": "borderTop" },
        "children": [
          { "id": "style-label", "type": "label", "props": { "text": "Style:", "variant": "muted" } },
          {
            "id": "btn-style-transparent",
            "type": "toggle",
            "props": { "param": "style", "mode": "discreteValue", "valueWhenOn": 0, "label": "Transparent" }
          },
          {
            "id": "btn-style-punchy",
            "type": "toggle",
            "props": { "param": "style", "mode": "discreteValue", "valueWhenOn": 1, "label": "Punchy" }
          },
          {
            "id": "btn-style-aggressive",
            "type": "toggle",
            "props": { "param": "style", "mode": "discreteValue", "valueWhenOn": 2, "label": "Aggressive" }
          }
        ]
      }
    ]
  }
}
