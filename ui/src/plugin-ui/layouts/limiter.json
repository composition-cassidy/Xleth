{
  "$xleth": "plugin-ui-layout",
  "schemaVersion": 1,
  "pluginId": "limiter",
  "name": "Default Limiter Layout",
  "panel": {
    "preferredSize": { "width": 760, "height": 460 }
  },
  "root": {
    "id": "root",
    "type": "panel",
    "children": [
      {
        "id": "viz-row",
        "type": "row",
        "style": { "paddingPx": [12, 12, 8, 12] },
        "children": [
          {
            "id": "limiter-viz",
            "type": "visualizer",
            "style": { "growsToFill": true },
            "props": {
              "source": "limiter.realtime",
              "preset": "limiterRealtime",
              "heightPx": 240
            }
          }
        ]
      },
      {
        "id": "body",
        "type": "row",
        "style": { "paddingPx": [4, 12, 12, 12], "gapPx": 12 },
        "children": [
          {
            "id": "controls",
            "type": "column",
            "style": { "growsToFill": true, "gapPx": 10 },
            "children": [
              {
                "id": "knob-row",
                "type": "row",
                "style": { "gapPx": 8, "justify": "center" },
                "children": [
                  { "id": "k-gain",    "type": "knob", "props": { "param": "gain",    "label": "GAIN",    "size": 60, "format": "dB1" } },
                  { "id": "k-ceiling", "type": "knob", "props": { "param": "ceiling", "label": "CEILING", "size": 52, "format": "dB1" } },
                  { "id": "k-release", "type": "knob", "props": { "param": "release", "label": "RELEASE", "size": 52, "format": "ms0" } }
                ]
              },
              {
                "id": "style-row",
                "type": "row",
                "style": { "paddingPx": [0, 4, 0, 4], "gapPx": 6, "align": "center" },
                "children": [
                  { "id": "style-label", "type": "label", "props": { "text": "Style:", "variant": "muted" } },
                  {
                    "id": "btn-style-transparent",
                    "type": "toggle",
                    "props": { "param": "style", "mode": "discreteValue", "valueWhenOn": 0, "label": "Transparent" }
                  },
                  {
                    "id": "btn-style-punchy",
                    "type": "toggle",
                    "props": { "param": "style", "mode": "discreteValue", "valueWhenOn": 1, "label": "Punchy" }
                  },
                  {
                    "id": "btn-style-aggressive",
                    "type": "toggle",
                    "props": { "param": "style", "mode": "discreteValue", "valueWhenOn": 2, "label": "Aggressive" }
                  }
                ]
              }
            ]
          },
          {
            "id": "gr-meter",
            "type": "meter",
            "style": { "widthPx": 32 },
            "props": {
              "source": { "kind": "effectMeter", "slot": "GAIN_REDUCTION" },
              "label": "GR",
              "unit": "dB",
              "range": { "min": 0, "max": 40, "scale": "linear" },
              "orientation": "vertical",
              "format": "dB1"
            }
          }
        ]
      }
    ]
  }
}
