{
  "$xleth": "plugin-ui-layout",
  "schemaVersion": 1,
  "pluginId": "transientproc",
  "name": "Default Transient Processor Layout",
  "panel": {
    "preferredSize": { "width": 540, "height": 440 }
  },
  "root": {
    "id": "root",
    "type": "panel",
    "children": [
      {
        "id": "viz-row",
        "type": "row",
        "style": { "paddingPx": [12, 12, 6, 12] },
        "children": [
          {
            "id": "transient-viz",
            "type": "visualizer",
            "style": { "growsToFill": true },
            "props": {
              "source": "transient.shaper",
              "preset": "transientShaper",
              "heightPx": 240
            }
          }
        ]
      },
      {
        "id": "mode-row",
        "type": "row",
        "style": { "paddingPx": [6, 12, 6, 12], "gapPx": 6, "align": "center", "justify": "center" },
        "props": { "variant": "borderTop" },
        "children": [
          { "id": "mode-label", "type": "label", "props": { "text": "Mode:", "variant": "muted" } },
          {
            "id": "btn-mode-envelope",
            "type": "toggle",
            "props": { "param": "midi_detect", "mode": "discreteValue", "valueWhenOn": 0, "label": "Envelope" }
          },
          {
            "id": "btn-mode-midi",
            "type": "toggle",
            "props": { "param": "midi_detect", "mode": "discreteValue", "valueWhenOn": 1, "label": "MIDI" }
          }
        ]
      },
      {
        "id": "body",
        "type": "row",
        "style": { "paddingPx": [12, 10, 8, 10], "gapPx": 0, "align": "start" },
        "children": [
          { "id": "s-attack",  "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "attack",       "label": "ATTACK",  "format": "pct0" } },
          { "id": "s-sustain", "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "sustain",      "label": "SUSTAIN", "format": "pct0" } },
          { "id": "tdiv-1", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          { "id": "s-speed",   "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "attack_speed", "label": "SPEED",   "format": "ms1"  } },
          { "id": "tdiv-2", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          { "id": "s-thresh",  "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "threshold",    "label": "THRESH",  "format": "dB1"  } },
          { "id": "tdiv-3", "type": "spacer", "style": { "widthPx": 18, "heightPx": 122 } },
          { "id": "dry-wet",   "type": "compressorDryWet", "style": { "widthPx": 124 }, "props": { "mixParam": "mix", "dryParam": "dry", "wetParam": "wet", "linkParam": "mix_linked" } }
        ]
      }
    ]
  }
}
