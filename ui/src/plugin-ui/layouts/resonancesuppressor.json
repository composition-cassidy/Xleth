{
  "$xleth": "plugin-ui-layout",
  "schemaVersion": 1,
  "pluginId": "resonancesuppressor",
  "name": "Default Resonance Suppressor Layout",
  "panel": {
    "preferredSize": { "width": 700, "height": 470 }
  },
  "root": {
    "id": "resonance-root",
    "type": "panel",
    "children": [
      {
        "id": "header",
        "type": "row",
        "style": { "paddingPx": [8, 12, 8, 12], "gapPx": 8, "align": "center" },
        "props": { "variant": "header" },
        "children": [
          {
            "id": "mode-segmented",
            "type": "row",
            "style": { "gapPx": 0, "align": "center" },
            "props": { "variant": "segmented" },
            "children": [
              { "id": "mode-soft", "type": "toggle", "props": { "param": "mode", "mode": "discreteValue", "valueWhenOn": 0, "label": "Soft" } },
              { "id": "mode-hard", "type": "toggle", "props": { "param": "mode", "mode": "discreteValue", "valueWhenOn": 1, "label": "Hard" } }
            ]
          },
          {
            "id": "processing-mode-segmented",
            "type": "row",
            "style": { "gapPx": 0, "align": "center" },
            "props": { "variant": "segmented" },
            "children": [
              { "id": "processing-mode-low", "type": "toggle", "props": { "param": "processing_mode", "mode": "discreteValue", "valueWhenOn": 0, "label": "Low Latency" } },
              { "id": "processing-mode-hq", "type": "toggle", "props": { "param": "processing_mode", "mode": "discreteValue", "valueWhenOn": 1, "label": "High Quality" } }
            ]
          },
          { "id": "header-spacer", "type": "spacer" },
          {
            "id": "quality-segmented",
            "type": "row",
            "style": { "gapPx": 0, "align": "center" },
            "props": { "variant": "segmented" },
            "children": [
              { "id": "quality-fast", "type": "toggle", "props": { "param": "quality", "mode": "discreteValue", "valueWhenOn": 0, "label": "Fast" } },
              { "id": "quality-normal", "type": "toggle", "props": { "param": "quality", "mode": "discreteValue", "valueWhenOn": 1, "label": "Normal" } },
              { "id": "quality-high", "type": "toggle", "props": { "param": "quality", "mode": "discreteValue", "valueWhenOn": 2, "label": "High" } }
            ]
          }
        ]
      },
      {
        "id": "workspace",
        "type": "row",
        "style": { "paddingPx": [8, 10, 12, 10], "gapPx": 8, "align": "stretch" },
        "children": [
          {
            "id": "main-stack",
            "type": "column",
            "style": { "growsToFill": true, "gapPx": 8 },
            "children": [
              {
                "id": "graph-card",
                "type": "panel",
                "style": { "paddingPx": [10, 10, 70, 10] },
                "children": [
                  {
                    "id": "resonance-viz-reduction",
                    "type": "visualizer",
                    "style": { "growsToFill": true },
                    "props": {
                      "source": "resonance.reduction",
                      "preset": "resonanceReduction",
                      "overlay": "resonanceCurve",
                      "heightPx": 150
                    }
                  }
                ]
              },
              {
                "id": "detection-card",
                "type": "panel",
                "style": { "paddingPx": [6, 10, 8, 10], "gapPx": 6 },
                "children": [
                  { "id": "detection-title", "type": "label", "props": { "text": "DETECTION", "variant": "muted" } },
                  {
                    "id": "detection-sliders",
                    "type": "row",
                    "style": { "growsToFill": true, "gapPx": 6, "align": "start" },
                    "children": [
                      { "id": "s-depth",       "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "depth",       "label": "DEPTH",       "format": "pct0" } },
                      { "id": "s-sharpness",   "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "sharpness",   "label": "SHARPNESS",   "format": "pct0" } },
                      { "id": "s-selectivity", "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "selectivity", "label": "SELECTIVITY", "format": "pct0" } },
                      { "id": "s-attack",      "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "attack",      "label": "ATTACK",      "format": "ms1"  } },
                      { "id": "s-release",     "type": "compressorSlider", "style": { "growsToFill": true }, "props": { "param": "release",     "label": "RELEASE",     "format": "ms0"  } }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "support-rail",
            "type": "column",
            "style": { "widthPx": 158, "gapPx": 8 },
            "children": [
              {
                "id": "output-card",
                "type": "panel",
                "style": { "paddingPx": [6, 10, 10, 10], "gapPx": 8 },
                "children": [
                  { "id": "output-title", "type": "label", "props": { "text": "OUTPUT", "variant": "muted" } },
                  {
                    "id": "output-body",
                    "type": "row",
                    "style": { "gapPx": 12, "align": "center", "justify": "center" },
                    "children": [
                      { "id": "s-mix",  "type": "compressorSlider", "style": { "widthPx": 52 }, "props": { "param": "mix",  "label": "MIX",  "format": "pct0" } }
                    ]
                  },
                  { "id": "h-trim", "type": "compressorHSlider", "props": { "param": "trim", "label": "TRIM", "format": "dB1_signed" } },
                  {
                    "id": "output-actions",
                    "type": "row",
                    "style": { "gapPx": 6, "align": "center" },
                    "children": [
                      { "id": "delta-toggle", "type": "toggle", "style": { "growsToFill": true }, "props": { "param": "delta", "mode": "boolParam", "label": "Delta Listen" } }
                    ]
                  }
                ]
              },
              {
                "id": "stereo-card",
                "type": "panel",
                "style": { "paddingPx": [6, 10, 10, 10], "gapPx": 8 },
                "children": [
                  { "id": "stereo-title", "type": "label", "props": { "text": "STEREO", "variant": "muted" } },
                  {
                    "id": "stereo-main-row",
                    "type": "row",
                    "style": { "gapPx": 8, "align": "center", "justify": "center" },
                    "children": [
                      {
                        "id": "stereo-mode-segmented",
                        "type": "row",
                        "style": { "gapPx": 0, "align": "center", "growsToFill": true },
                        "props": { "variant": "segmented" },
                        "children": [
                          { "id": "stereo-mode-stereo", "type": "toggle", "props": { "param": "stereo_mode", "mode": "discreteValue", "valueWhenOn": 0, "label": "Stereo" } },
                          { "id": "stereo-mode-mid",    "type": "toggle", "props": { "param": "stereo_mode", "mode": "discreteValue", "valueWhenOn": 1, "label": "Mid" } },
                          { "id": "stereo-mode-side",   "type": "toggle", "props": { "param": "stereo_mode", "mode": "discreteValue", "valueWhenOn": 2, "label": "Side" } }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
