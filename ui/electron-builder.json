{
  "appId": "com.xleth.app",
  "productName": "XLETH",
  "files": ["dist/**/*", "src/plugin-ui/layouts/*.json", "src/engine-pipe-client.js", "main.js", "preload.js", "runtimePaths.js", "workspaceBackdropCapability.js", "splash.html", "splash-preload.js"],
  "directories": {
    "output": "../dist"
  },
  "asar": true,
  "asarUnpack": ["**/*.node"],
  "compression": "normal",
  "extraResources": [
    {
      "from": "../build/xleth-engine.exe",
      "to": "engine/xleth-engine.exe"
    },
    {
      "from": "../xlethpopup.png",
      "to": "xlethpopup.png"
    },
    {
      "from": "../bridge/build/Release",
      "to": "bridge",
      "filter": [
        "xleth_native.node",
        "*.dll",
        "xleth-editor-host.exe",
        "xleth-plugin-scanner.exe"
      ]
    },
    {
      "from": "../shm_helper/build/Release",
      "to": "shm_helper",
      "filter": ["shm_helper.node"]
    },
    {
      "from": "../media",
      "to": "media",
      "filter": ["**/*"]
    },
    {
      "from": "../art",
      "to": "art",
      "filter": ["**/*"]
    },
    {
      "from": "../build/engine/XlethEngine_artefacts/Release",
      "to": "engine",
      "filter": ["XlethEngine.exe", "*.dll"]
    },
    {
      "from": "../vendor/ffmpeg/bin",
      "to": "ffmpeg",
      "filter": ["ffmpeg.exe", "ffprobe.exe", "*.dll"]
    },
    {
      "from": "../vendor/ffmpeg",
      "to": "ffmpeg",
      "filter": ["LICENSE", "README.txt"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "portable": {
    "artifactName": "Xleth-${version}-portable.${ext}",
    "unpackDirName": "Xleth-${version}"
  }
}