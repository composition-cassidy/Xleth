{
  "appId": "com.xleth.app",
  "productName": "XLETH",
  "files": ["dist/**/*", "src/plugin-ui/layouts/*.json", "main.js", "preload.js", "runtimePaths.js", "workspaceBackdropCapability.js", "update-checker.js", "splash.html", "splash-preload.js"],
  "directories": {
    "output": "../dist"
  },
  "asar": true,
  "asarUnpack": ["**/*.node"],
  "compression": "normal",
  "extraResources": [
    {
      "from": "../xlethpopup.png",
      "to": "xlethpopup.png"
    },
    {
      "from": "../bridge/build/Release",
      "to": "bridge",
      "filter": [
        "xleth_native.node",
        "*.dll",
        "xleth-editor-host.exe",
        "xleth-plugin-scanner.exe"
      ]
    },
    {
      "from": "../shm_helper/build/Release",
      "to": "shm_helper",
      "filter": ["shm_helper.node"]
    },
    {
      "from": "../media",
      "to": "media",
      "filter": ["**/*"]
    },
    {
      "from": "../art",
      "to": "art",
      "filter": ["*.png", "*.jpg", "*.jpeg", "*.webp"]
    },
    {
      "from": "../build/engine/XlethEngine_artefacts/Release",
      "to": "engine",
      "filter": ["XlethEngine.exe", "*.dll"]
    },
    {
      "from": "../vendor/ffmpeg/bin",
      "to": "ffmpeg",
      "filter": ["ffmpeg.exe", "ffprobe.exe", "*.dll"]
    },
    {
      "from": "../vendor/ffmpeg",
      "to": "ffmpeg",
      "filter": ["LICENSE", "README.txt"]
    },
    {
      "from": "../vendor/node",
      "to": "node",
      "filter": ["node.exe"]
    },
    {
      "from": "addon-worker.js",
      "to": "worker/addon-worker.js"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "portable": {
    "artifactName": "Xleth-${version}-portable.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "deleteAppDataOnUninstall": false,
    "artifactName": "Xleth-${version}-setup.${ext}"
  }
}
