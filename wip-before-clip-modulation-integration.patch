+/* ── Track color popover ─────────────────────────────────────────────── */
+
+.track-color-popover {
+  position: fixed;
+  z-index: 9000;
+  background: var(--theme-bg-secondary);
+  border: 1px solid var(--theme-border-subtle);
+  border-radius: var(--radius-sm);
+  padding: 8px;
+  min-width: 130px;
+  box-shadow: var(--theme-depth-elevation-1-top-highlight),
+              var(--theme-depth-elevation-2-outer-shadow);
+}
+
+.track-color-popover-title {
+  font-size: 10px;
+  font-weight: 600;
+  letter-spacing: 0.4px;
+  text-transform: uppercase;
+  color: var(--theme-text-subtle);
+  margin-bottom: 6px;
+}
+
+.track-color-auto-option {
+  width: 100%;
+  height: 22px;
+  font-size: 11px;
+  background: var(--theme-bg-inset);
+  border: 1px solid var(--theme-border-subtle);
+  border-radius: var(--radius-xs, 3px);
+  color: var(--theme-text-secondary);
+  cursor: pointer;
+  margin-bottom: 6px;
+  transition: background var(--transition-fast), border-color var(--transition-fast),
+              color var(--transition-fast);
+}
+
+.track-color-auto-option:hover {
+  background: var(--theme-bg-hover);
+  color: var(--theme-text-primary);
+}
+
+.track-color-auto-option.is-selected {
+  background: var(--theme-depth-pressed-bg);
+  border-color: var(--theme-border-focus);
+  color: var(--theme-accent);
+  box-shadow: var(--theme-depth-pressed-inner-shadow);
+}
+
+.track-color-swatch-grid {
+  display: grid;
+  grid-template-columns: repeat(4, 1fr);
+  gap: 4px;
+}
+
+.track-color-swatch {
+  width: 22px;
+  height: 22px;
+  border-radius: var(--radius-xs, 3px);
+  border: 1px solid rgba(0, 0, 0, 0.2);
+  cursor: pointer;
+  padding: 0;
+  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
+}
+
+.track-color-swatch:hover {
+  transform: scale(1.12);
+  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.25);
+}
+
+.track-color-swatch.is-selected {
+  box-shadow: 0 0 0 2px var(--theme-bg-secondary),
+              0 0 0 3px var(--theme-border-focus);
+}
+
+/* ── Custom color section ──────────────────────────────────────────── */
+
+.track-color-custom-section {
+  margin-top: 6px;
+  padding-top: 6px;
+  border-top: 1px solid var(--theme-border-subtle);
+}
+
+.track-color-custom-section.is-selected .track-color-custom-label {
+  color: var(--theme-accent);
+}
+
+.track-color-custom-label {
+  font-size: 10px;
+  font-weight: 600;
+  letter-spacing: 0.4px;
+  text-transform: uppercase;
+  color: var(--theme-text-muted);
+  margin-bottom: 4px;
+}
+
+.track-color-custom-row {
+  display: flex;
+  align-items: center;
+  gap: 4px;
+}
+
+.track-color-custom-input {
+  width: 22px;
+  height: 22px;
+  padding: 0;
+  border: 1px solid var(--theme-border-subtle);
+  border-radius: var(--radius-xs, 3px);
+  background: none;
+  cursor: pointer;
+  flex-shrink: 0;
+}
+
+.track-color-custom-input::-webkit-color-swatch-wrapper { padding: 0; }
+.track-color-custom-input::-webkit-color-swatch { border: none; border-radius: 2px; }
+
+.track-color-hex-input {
+  flex: 1;
+  height: 22px;
+  padding: 0 4px;
+  font-size: 11px;
+  font-family: var(--font-mono, monospace);
+  background: var(--theme-bg-inset);
+  border: 1px solid var(--theme-border-subtle);
+  border-radius: var(--radius-xs, 3px);
+  color: var(--theme-text-primary);
+  min-width: 0;
+}
+
+.track-color-hex-input:focus {
+  outline: none;
+  border-color: var(--theme-border-focus);
+}
+
+.track-color-hex-input.is-invalid {
+  border-color: var(--theme-danger, #ef4444);
+}
+
+.track-color-custom-error {
+  font-size: 10px;
+  color: var(--theme-danger, #ef4444);
+  margin-top: 3px;
+}
+
+/* ── Timeline Display popover ────────────────────────────────────────── */
+.tl-display-root { position: relative; }
+
+.tl-display-popover {
+  position: absolute;
+  top: calc(100% + 4px);
+  right: 0;
+  z-index: 210;
+  background: var(--theme-bg-secondary);
+  border: 1px solid var(--theme-border-subtle);
+  border-radius: var(--radius-sm);
+  padding: 8px 10px;
+  min-width: 220px;
+  box-shadow:
+    var(--theme-depth-elevation-1-top-highlight),
+    var(--theme-depth-elevation-2-outer-shadow);
+}
+
+.tl-display-section { margin-bottom: 8px; }
+.tl-display-section:last-child { margin-bottom: 0; }
+
+.tl-display-label {
+  font-size: 9px;
+  font-weight: 600;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  color: var(--theme-text-muted);
+  margin-bottom: 3px;
+}
+
+.tl-display-group {
+  display: flex;
+  gap: 1px;
+}
+
+.tl-display-btn {
+  flex: 1;
+  height: 20px;
+  font-size: 10px;
+  border: 1px solid var(--theme-border-subtle);
+  background: var(--theme-bg-inset);
+  color: var(--theme-text-secondary);
+  cursor: pointer;
+  padding: 0 4px;
+  transition: background var(--transition-fast), color var(--transition-fast),
+              border-color var(--transition-fast), box-shadow var(--transition-fast);
+}
+.tl-display-btn:first-child { border-radius: 3px 0 0 3px; }
+.tl-display-btn:last-child  { border-radius: 0 3px 3px 0; }
+.tl-display-btn:hover {
+  background: var(--theme-bg-hover);
+  color: var(--theme-text-primary);
+}
+.tl-display-btn.active {
+  background: var(--theme-depth-pressed-bg);
+  border-color: var(--theme-border-focus);
+  color: var(--theme-accent);
+  box-shadow: var(--theme-depth-pressed-inner-shadow);
+}
+.tl-display-btn:disabled {
+  opacity: 0.35;
+  cursor: default;
+  pointer-events: none;
+}
+
 .ws-edit-item {
   display: flex;
   align-items: center;
